# ##############################################################################
# .env.example - Modelo de Configurações do Ambiente para Neuralis X
# Renomeie este arquivo para .env no seu ambiente local e preencha os valores.
# ATENÇÃO: Nunca adicione o arquivo .env real ao controle de versão!
# ##############################################################################

# Identificadores de Rastreamento (Analytics / Pixels)
META_PIXEL_ID=seu_pixel_id_aqui
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Chaves de Integração de E-mail Marketing / Lead Capture (Exemplo)
ACTIVE_CAMPAIGN_API_URL=https://suaconta.api-us1.com
ACTIVE_CAMPAIGN_API_KEY=sua_chave_de_api_aqui

# Configurações de Checkout / Gateways de Pagamento (Exemplo)
STRIPE_PUBLIC_KEY=insira_sua_chave_publica_stripe_aqui
STRIPE_SECRET_KEY=insira_sua_chave_secreta_stripe_aqui
