screen.png

# Pastas e arquivos de IDE / Editores de Código
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Arquivos do Sistema Operacional
.DS_Store
.DS_Store?
._*
